# ── App ───────────────────────────────────────────
APP_ENV=development
PORT=8080

# ── Database ──────────────────────────────────────
DATABASE_URL=postgres://postgres:postgres@localhost:5432/jinnxfit?sslmode=disable

# ── JWT ───────────────────────────────────────────
JWT_SECRET=change_me_in_production

# ── Email (choose ONE: Resend OR SMTP) ───────────
RESEND_API_KEY=
EMAIL_FROM=

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# ── Razorpay ──────────────────────────────────────
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
RAZORPAY_PLAN_ID=

# ── LiveKit ───────────────────────────────────────
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
LIVEKIT_HOST=wss://your-livekit-host.livekit.cloud

# ── Anthropic Claude ──────────────────────────────
ANTHROPIC_API_KEY=

# ── Chat limits ───────────────────────────────────
CHATBOT_DAILY_LIMIT_FREE=20
CHATBOT_MAX_HISTORY=10

# ── Cloudflare R2 (storage) ───────────────────────
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
